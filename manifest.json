{
  "id": "qwen_image_edit_gguf",
  "name": "Qwen-Image-Edit (GGUF) Image Edit",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/qwen_image_edit_modly",
  "description": "Instruction-based image editing with Alibaba's Qwen-Image-Edit, loaded as a 4-bit GGUF transformer. Optimized defaults: 20 steps, CFG 3.0, auto VRAM detection to pick max_speed (no offload) when possible. Apache-2.0 and ungated.",
  "version": "1.1.0",
  "author": "iammojogo",
  "vram_gb": 8,
  "tags": [
    "image-to-image",
    "image-editing",
    "qwen",
    "gguf",
    "i2i"
  ],
  "nodes": [
    {
      "id": "edit",
      "name": "Edit Image",
      "input": "image",
      "inputs": ["image"],
      "output": "image",
      "hf_repo": "calcuis/qwen-image-edit-gguf",
      "download_check": "model_index.json",
      "params_schema": [
        {
          "id": "prompt",
          "label": "Edit Instruction",
          "type": "string",
          "default": "",
          "tooltip": "e.g. rotate the object 180 degrees to show the back"
        },
        {
          "id": "memory_mode",
          "label": "Memory Mode",
          "type": "select",
          "default": "auto",
          "options": [
            { "value": "auto",      "label": "Auto (model CPU offload)" },
            { "value": "balanced",  "label": "Offload (model CPU offload)" },
            { "value": "max_speed", "label": "Max Speed (no offload, 24GB+)" }
          ]
        },
        {
          "id": "gguf_quant",
          "label": "Transformer Quant",
          "type": "select",
          "default": "q3_k_m",
          "options": [
            { "value": "q2_k",   "label": "Q2_K  · 7GB  (8-12GB, lowest quality)" },
            { "value": "q3_k_m", "label": "Q3_K_M · 9GB  (12GB) — default" },
            { "value": "q4_k_m", "label": "Q4_K_M · 12GB (16GB)" },
            { "value": "q5_k_m", "label": "Q5_K_M · 14GB (16-24GB)" },
            { "value": "q8_0",   "label": "Q8_0  · 22GB (24GB+)" }
          ]
        },
        {
          "id": "steps",
          "label": "Steps",
          "type": "int",
          "default": 20,
          "min": 5,
          "max": 30
        },
        {
          "id": "true_cfg_scale",
          "label": "CFG Scale",
          "type": "float",
          "default": 3.0,
          "min": 1,
          "max": 10
        },
        {
          "id": "num_images",
          "label": "Number of Outputs",
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 4
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 0,
          "min": 0,
          "max": 4294967295
        }
      ]
    }
  ],
  "generator_class": "QwenImageEditGenerator"
}
